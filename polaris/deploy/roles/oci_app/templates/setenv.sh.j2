export SERVICE_DATA_HOME="{{ oci_app_service_data_home }}"
export SERVICE_LOG_HOME="{{ oci_app_service_log_home }}"
export SERVICE_TMP_HOME="{{ oci_app_service_install_tmp_home }}"
export PORT={{ oci_app_service_port }}
{% if oci_app_env_dict is defined %}
{% for key, value in oci_app_env_dict.items() %}
export {{ key }}="{{ value }}"
{% endfor %}
{% endif %}
